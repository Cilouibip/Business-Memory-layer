{
  "name": "bml",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "e2e:youtube": "node --env-file=.env.local ./node_modules/.bin/tsx scripts/e2e-youtube.ts",
    "pipeline:run": "node --env-file=.env.local ./node_modules/.bin/tsx scripts/run-pipeline.ts",
    "drain:notion": "node --env-file=.env.local ./node_modules/.bin/tsx scripts/drain-pipeline.ts --source notion",
    "sync:gdrive": "node --env-file=.env.local ./node_modules/.bin/tsx scripts/run-pipeline.ts --sources gdrive",
    "cron:run": "node --env-file=.env.local -e \"fetch('http://localhost:3000/api/cron/sync', { method: 'GET', headers: { 'Authorization': 'Bearer ' + process.env.CRON_SECRET } }).then(r => r.json()).then(console.log).catch(console.error)\"",
    "mcp:start": "node --env-file=.env.local ./node_modules/.bin/tsx src/mcp/server.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
